# ── App ───────────────────────────────────────────────────────────────────────
# API role: general | transfer | all
# "all" runs both General (7001) and Transfer (7010) in the same process (dev)
APP_API_ROLE=all
NODE_ENV=development

# ── PostgreSQL credentials (shared across all DBs) ────────────────────────────
PG_USER=your_pg_user
PG_PASSWORD=your_pg_password
PG_PORT=5432

# ── PostgreSQL hosts ──────────────────────────────────────────────────────────
PG_META_HOST=localhost

PG_SHARD_0_HOST=localhost
PG_SHARD_1_HOST=localhost
PG_SHARD_2_HOST=localhost
PG_SHARD_3_HOST=localhost

# ── Connection pool sizes ─────────────────────────────────────────────────────
PG_META_POOL_MAX=5
PG_SHARD_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Transfer queue tuning ─────────────────────────────────────────────────────
TRANSFER_QUEUE_REJECT_THRESHOLD=240
TRANSFER_QUEUE_MAX_LENGTH=300
TRANSFER_QUEUE_OWNER_TTL_MS=10000
TRANSFER_QUEUE_OWNER_REFRESH_MS=3000
TRANSFER_QUEUE_BATCH_SIZE=50
TRANSFER_QUEUE_BLOCK_TIMEOUT_SEC=1
